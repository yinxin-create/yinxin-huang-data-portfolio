---
import {
  navBarLinks,
  identity,
  measurementId,
  googleSiteVerification,
} from "../config";
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import type { SEOInfo } from "../types/config";
import { withBase, withoutBase } from "../utils/paths";
import "@styles/base.css";

interface Props {
  seo: SEOInfo;
}

const { seo } = Astro.props;
const absoluteUrl = (path: string) =>
  path.startsWith("http://") || path.startsWith("https://")
    ? path
    : new URL(withBase(path), Astro.site).toString();
const ogImageUrl = absoluteUrl(seo.image);
const currentPath = withoutBase(Astro.url.pathname);
---

<script>
  const linkMenuButton = document.getElementById(
    "link-menu-button",
  ) as HTMLButtonElement;
  const linkMenu = document.getElementById("link-menu") as HTMLDivElement;
  const openIndicator = document.getElementById(
    "open-indicator",
  ) as HTMLSpanElement;

  linkMenuButton.addEventListener("click", () => {
    const isOpen = linkMenu.classList.contains("opacity-0");
    if (isOpen) {
      linkMenu.classList.remove("pointer-events-none");
      linkMenu.classList.remove("opacity-0");
      linkMenu.classList.add("pointer-events-auto");
      openIndicator.innerText = "×";
      linkMenuButton.setAttribute("aria-expanded", "true");
    } else {
      linkMenu.classList.add("pointer-events-none");
      linkMenu.classList.add("opacity-0");
      linkMenu.classList.remove("pointer-events-auto");
      openIndicator.innerText = "+";
      linkMenuButton.setAttribute("aria-expanded", "false");
    }
  });

  document.addEventListener("click", (event) => {
    const isLinkMenuButtonClicked =
      event.target === linkMenuButton ||
      linkMenuButton.contains(event.target as Node);
    const isLinkMenuClicked =
      event.target === linkMenu || linkMenu.contains(event.target as Node);

    if (!isLinkMenuButtonClicked && !isLinkMenuClicked) {
      linkMenu.classList.add("pointer-events-none");
      linkMenu.classList.add("opacity-0");
      linkMenu.classList.remove("pointer-events-auto");
      openIndicator.innerText = "+";
      linkMenuButton.setAttribute("aria-expanded", "false");
    }
  });
</script>

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="apple-touch-icon" sizes="180x180" href={withBase("/apple-touch-icon.png")} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase("/favicon-32x32.png")} />
    <link rel="icon" type="image/png" sizes="16x16" href={withBase("/favicon-16x16.png")} />
    <link rel="manifest" href={withBase("/site.webmanifest")} />
    <link rel="sitemap" href={withBase("/sitemap-index.xml")} />
    <link rel="canonical" href={seo.url} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Kanit:wght@500;600&family=KoHo:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{seo.title}</title>

    <!-- HTML Meta Tags -->
    <meta name="description" content={seo.description} />

    <!-- Open Graph / Facebook Meta Tags -->
    <meta property="og:url" content={seo.url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={seo.domain} />
    <meta property="twitter:url" content={seo.url} />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="google-site-verification" content={googleSiteVerification} />
    <!-- Google Analytics -->
    <GoogleAnalytics measurementId={measurementId} />
    <!-- Google Analytics -->

    <!-- JSON-LD Structured Data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            "@id": `${seo.url}#person`,
            name: identity.name,
            url: seo.url,
            image: {
              "@type": "ImageObject",
              url: ogImageUrl,
            },
            jobTitle: "Data analysis portfolio",
            worksFor: {
              "@type": "Organization",
              name: "Open to roles",
            },
            knowsAbout: [
              "Python",
              "SQL",
              "Power BI",
              "Tableau",
              "Pandas",
              "World Bank Open Data",
              "Data visualization",
            ],
          },
          {
            "@type": "WebSite",
            "@id": `${seo.url}#website`,
            url: seo.url,
            name: identity.name,
            description: seo.description,
            publisher: {
              "@id": `${seo.url}#person`,
            },
            inLanguage: "en",
          },
          {
            "@type": ["WebPage", "ProfilePage"],
            "@id": seo.url,
            url: seo.url,
            name: seo.title,
            description: seo.description,
            isPartOf: {
              "@id": `${seo.url}#website`,
            },
            about: {
              "@id": `${seo.url}#person`,
            },
            mainEntity: {
              "@id": `${seo.url}#person`,
            },
            image: {
              "@type": "ImageObject",
              url: ogImageUrl,
            },
            inLanguage: "en",
          },
        ],
      })}
    />
  </head>
  <body>
    <header>
      <div
        class="px-6 py-6 max-w-6xl mx-auto flex items-center justify-between"
      >
        <a href={withBase("/")}>
          <img
            src={withBase(identity.logo)}
            alt={"Logo"}
            width={50}
            height={50}
            loading="eager"
            decoding="async"
            class="w-[50px] h-[50px] object-cover"
          />
        </a>
        <nav class="navbar">
          <ul class="hidden sm:flex sm:items-center sm:gap-0">
            {
              navBarLinks.map((link) => {
                const isActive =
                  currentPath === link.url ||
                  (link.url !== "/" && currentPath.startsWith(link.url));
                return (
                  <li>
                    <a
                      class={`block px-3 py-2 text-sm rounded transition-colors duration-150 ${
                        isActive
                          ? "text-[#0f766e]"
                          : "text-[#344049]/65 hover:text-[#18232c] hover:bg-[#0f766e]/10"
                      }`}
                      href={link.external ? link.url : withBase(link.url)}
                      target={link.external ? "_blank" : "_self"}
                    >
                      {link.title}
                    </a>
                  </li>
                );
              })
            }
          </ul>
          <!-- Mobile menu -->
          <div class="relative sm:hidden">
            <button
              id="link-menu-button"
              class="flex items-center px-3 py-2 text-sm text-[#344049]/65 hover:text-[#18232c] rounded transition-colors duration-150"
              aria-label="Toggle navigation menu"
              aria-expanded="false"
              aria-controls="link-menu"
            >
              <span>Menu</span>
              <span id="open-indicator" class="ml-1.5 text-[#0f766e]">+</span>
            </button>
            <div
              id="link-menu"
                class="absolute top-full mt-2 right-0 bg-white border border-[#d8d2c7] rounded-lg w-48 transition-all ease-in-out duration-200 opacity-0 z-50 pointer-events-none backdrop-blur-md shadow-lg"
            >
              <ul class="py-2">
                {
                  navBarLinks.map((link) => {
                    const isActive =
                      currentPath === link.url ||
                      (link.url !== "/" && currentPath.startsWith(link.url));
                    return (
                      <li>
                        <a
                          class={`block px-4 py-3 text-sm transition-all duration-200 ${
                            isActive
                              ? "text-[#0f766e] font-medium bg-[#0f766e]/10 border-r-2 border-[#0f766e]"
                              : "opacity-80 hover:opacity-100 hover:bg-[#0f766e]/10 hover:text-[#18232c]"
                          }`}
                          href={link.external ? link.url : withBase(link.url)}
                          target={link.external ? "_blank" : "_self"}
                        >
                          {link.title}
                        </a>
                      </li>
                    );
                  })
                }
              </ul>
            </div>
          </div>
        </nav>
      </div>
    </header>
    <main class="mb-32">
      <slot />
    </main>
    <footer></footer>
  </body>
</html>
